generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

model Product {
  id               String                @id @default(cuid())
  title            String
  slug             String                @unique
  description      String?
  image            String?
  images           String[]              @default([])
  price            Float?
  originalPrice    Float?
  discount         Float?
  amazonLink       String?
  flipkartLink     String?
  featured         Boolean               @default(false)
  categoryId       String?
  createdAt        DateTime              @default(now())
  updatedAt        DateTime              @updatedAt
  cashbackAmazon   Float?                @default(0)
  cashbackFlipkart Float?                @default(0)
  cashbackPaytm    Float?                @default(0)
  cashbackPhonePe  Float?                @default(0)
  availability     String?
  meeshoLink       String?
  rating           Float?
  seller           String?
  affiliateUrl     String?
  originalUrl      String?
  isPublic         Boolean               @default(true)
  boughtCount      Int?
  bankOffers       String[]              @default([])
  deliveryInfo     String?
  affiliateClicks  AffiliateClick[]
  priceAlerts      PriceAlert[]
  reviews          ProductReview[]
  category         Category?             @relation(fields: [categoryId], references: [id])
  priceHistory     ProductPriceHistory[]
  trackedBy        TrackedProduct[]
  cartItems        CartItem[]
  orderItems       OrderItem[]
}

model ProductReview {
  id        String   @id @default(cuid())
  productId String
  product   Product  @relation(fields: [productId], references: [id], onDelete: Cascade)
  rating    Float
  title     String?
  comment   String
  author    String?
  createdAt DateTime @default(now())
}


model Category {
  id       String    @id @default(cuid())
  name     String
  slug     String    @unique
  icon     String?
  products Product[]
}

model Post {
  id        String   @id @default(cuid())
  title     String
  slug      String   @unique
  content   String
  excerpt   String?
  image     String?
  published Boolean  @default(false)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model Admin {
  id       String @id @default(cuid())
  email    String @unique
  password String
}

model Complaint {
  id        String   @id @default(cuid())
  name      String
  email     String
  subject   String
  message   String
  status    String   @default("open") // open | in_review | resolved
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model Coupon {
  id          String    @id @default(cuid())
  title       String
  code        String
  description String?
  discount    String?
  store       String
  link        String?
  expiry      DateTime?
  isVerified  Boolean   @default(true)
  isSecret    Boolean   @default(false)
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt
}

model PriceAlert {
  id          String    @id @default(cuid())
  email       String?
  phone       String?
  targetPrice Float
  productId   String
  isActive    Boolean   @default(true)
  emailSentAt DateTime?
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt
  product     Product   @relation(fields: [productId], references: [id])
}

model ProductPriceHistory {
  id        String   @id @default(cuid())
  productId String
  price     Float
  platform  String?  @default("unknown")
  timestamp DateTime @default(now())
  product   Product  @relation(fields: [productId], references: [id])
}

model TrackedProduct {
  id          String   @id @default(cuid())
  userId      String?
  email       String?
  productId   String
  targetPrice Float?
  isActive    Boolean  @default(true)
  createdAt   DateTime @default(now())
  product     Product  @relation(fields: [productId], references: [id])
}

model AffiliateClick {
  id        String   @id @default(cuid())
  productId String
  platform  String?  @default("unknown")
  sessionId String?
  ip        String?
  userAgent String?
  timestamp DateTime @default(now())
  product   Product  @relation(fields: [productId], references: [id])
}

model SiteSettings {
  id                 String   @id @default("default")
  defaultTheme       String   @default("dark")
  siteName           String   @default("ZenCult")
  siteTagline        String   @default("Best Amazon, Flipkart & Myntra Deals")
  logoUrl            String?
  faviconUrl         String?
  geminiApiKey       String?
  resendApiKey       String?
  scrapingBeeApiKey  String?
  razorpayKeyId      String?
  razorpayKeySecret  String?
  contactEmail       String?
  whatsappNumber     String?
  instagramUrl       String?
  facebookUrl        String?
  twitterUrl         String?
  youtubeUrl         String?
  announcementText   String?
  announcementLink   String?
  shippingFee        Float?   @default(0)
  freeShippingThreshold Float? @default(500)
  updatedAt          DateTime @updatedAt
}

model PageView {
  id        String   @id @default(cuid())
  url       String
  sessionId String
  timestamp DateTime @default(now())
}

model SyncLog {
  id               String   @id @default(cuid())
  triggeredBy      String   @default("manual") // "manual" | "cron"
  status           String   @default("success") // "success" | "error"
  total            Int      @default(0)
  updated          Int      @default(0)
  failed           Int      @default(0)
  alertsSent       Int      @default(0)
  errorMessage     String?
  durationMs       Int?
  createdAt        DateTime @default(now())
}

// ─── Customer Accounts ───────────────────────────────────────────────────────
model User {
  id            String     @id @default(cuid())
  name          String
  email         String     @unique
  password      String
  phone         String?
  address       String?
  city          String?
  state         String?
  pincode       String?
  createdAt     DateTime   @default(now())
  updatedAt     DateTime   @updatedAt
  cartItems     CartItem[]
  orders        Order[]
}

// ─── Cart ─────────────────────────────────────────────────────────────────────
model CartItem {
  id        String   @id @default(cuid())
  userId    String
  productId String
  quantity  Int      @default(1)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  product   Product  @relation(fields: [productId], references: [id], onDelete: Cascade)

  @@unique([userId, productId])
}

// ─── Orders ───────────────────────────────────────────────────────────────────
model Order {
  id                String      @id @default(cuid())
  userId            String
  status            String      @default("pending")  // pending | confirmed | ordered | shipped | delivered | cancelled
  paymentMethod     String      @default("COD")       // COD | online
  paymentStatus     String      @default("pending")   // pending | paid | failed
  razorpayOrderId   String?
  razorpayPaymentId String?
  subtotal          Float
  shippingFee       Float       @default(0)
  total             Float
  // Snapshot of shipping address at time of order
  shippingName      String
  shippingPhone     String
  shippingAddress   String
  shippingCity      String
  shippingState     String
  shippingPincode   String
  // Admin notes
  adminNote         String?
  createdAt         DateTime    @default(now())
  updatedAt         DateTime    @updatedAt
  user              User        @relation(fields: [userId], references: [id])
  items             OrderItem[]
}

model OrderItem {
  id           String  @id @default(cuid())
  orderId      String
  productId    String
  productTitle String
  productImage String?
  quantity     Int
  price        Float   // price snapshot at time of order
  order        Order   @relation(fields: [orderId], references: [id], onDelete: Cascade)
  product      Product @relation(fields: [productId], references: [id])
}
